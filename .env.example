# Optional Discord alert webhooks used by monitor scripts.
DISCORD_MONITOR_WARNING_WEBHOOK_URL=
DISCORD_MONITOR_CRITICAL_WEBHOOK_URL=
# Optional. Defaults to DISCORD_MONITOR_CRITICAL_WEBHOOK_URL so firing/recovery pairs stay together.
DISCORD_MONITOR_RECOVERY_WEBHOOK_URL=

# Default paths on the NUC.
NUC_WEB_ROOT=/opt/nuc-web
HOME_SERVER_CONFIG=/opt/nuc-web/config/sites.yaml
HOME_SERVER_ENV_FILE=/opt/nuc-web/.env
HOME_SERVER_STATE_DIR=/var/lib/home-server

# Gateway monitor timer cadence.
HOME_SERVER_MONITOR_ON_BOOT_SEC=2min
HOME_SERVER_MONITOR_INTERVAL=5min

# Health check behavior.
HEALTH_TIMEOUT_MS=5000
# Set to true for first install if public DNS/Tunnel routes are not ready yet.
HOME_SERVER_SKIP_PUBLIC_HEALTH_CHECKS=false

# Cron monitor behavior.
HOME_SERVER_SKIP_CRON_CHECKS=false
HOME_SERVER_SKIP_CRON_DAEMON_CHECK=false
# Default freshness window for configured cron log files when a job omits maxAgeMinutes.
HOME_SERVER_CRON_MAX_AGE_MINUTES=1500
# Number of bytes read from the end of each configured cron log file.
HOME_SERVER_CRON_LOG_TAIL_BYTES=65536

# Optional override when installing generated Cloudflare Tunnel config.
CLOUDFLARED_CONFIG_FILE=/etc/cloudflared/config.yml
